        "# ======================================================\n",
        "# ONBOARDING & INDUCTION PSYCHOLOGICAL PROFILER (HR SAFE)\n",
        "# ======================================================\n",
        "\n",
        "!pip install python-docx openpyxl fuzzywuzzy python-Levenshtein\n",
        "\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import os\n",
        "from docx import Document\n",
        "from docx.shared import Inches\n",
        "from google.colab import files\n",
        "from fuzzywuzzy import fuzz\n",
        "import math\n",
        "\n",
        "# ===============================\n",
        "# SETUP\n",
        "# ===============================\n",
        "os.makedirs(\"Reports\", exist_ok=True)\n",
        "os.makedirs(\"Plots\", exist_ok=True)\n",
        "\n",
        "print(\"Upload BOTH Excel files (Induction + Onboarding)\")\n",
        "uploaded = files.upload()\n",
        "\n",
        "files_list = list(uploaded.keys())\n",
        "induction_file = [f for f in files_list if \"Induction\" in f][0]\n",
        "onboarding_file = [f for f in files_list if \"Onboarding\" in f][0]\n",
        "\n",
        "induction_df = pd.read_excel(induction_file)\n",
        "onboarding_df = pd.read_excel(onboarding_file)\n",
        "\n",
        "# ===============================\n",
        "# SCORING MAP\n",
        "# ===============================\n",
        "SCORE_MAP = {\n",
        "    \"Strongly Agree\": 5,\n",
        "    \"Agree\": 4,\n",
        "    \"Neutral\": 3,\n",
        "    \"Disagree\": 2,\n",
        "    \"Strongly Disagree\": 1,\n",
        "    \"Very Happy\": 5,\n",
        "    \"Somewhat Happy\": 4,\n",
        "    \"Somewhat Unhappy\": 2,\n",
        "    \"Very Unhappy\": 1,\n",
        "    \"Yes\": 5,\n",
        "    \"No\": 1\n",
        "}\n",
        "\n",
        "def decode(val):\n",
        "    if pd.isna(val):\n",
        "        return 3\n",
        "    return SCORE_MAP.get(str(val).strip(), 3)\n",
        "\n",
        "# ===============================\n",
        "# COLUMN MATCHER\n",
        "# ===============================\n",
        "def find_column(df, keywords):\n",
        "    best_col, best_score = None, 0\n",
        "    for col in df.columns:\n",
        "        for kw in keywords:\n",
        "            score = fuzz.partial_ratio(col.lower(), kw.lower())\n",
        "            if score > best_score:\n",
        "                best_score = score\n",
        "                best_col = col\n",
        "    return best_col\n",
        "\n",
        "# ===============================\n",
        "# INDUCTION COLUMN MAP\n",
        "# ===============================\n",
        "induction_map = {\n",
        "    \"prehire\": [\"pre hire\", \"pre-hire\"],\n",
        "    \"documents\": [\"documents\", \"induction plan\"],\n",
        "    \"buddy\": [\"buddy was helpful\"],\n",
        "    \"it\": [\"IT resources\"],\n",
        "    \"admin\": [\"Admin resources\"],\n",
        "    \"finance\": [\"Finance process\"],\n",
        "    \"manager\": [\"welcomed by your manager\"],\n",
        "    \"support\": [\"necessary support\"],\n",
        "    \"satisfaction\": [\"satisfied with the hiring process\"]\n",
        "}\n",
        "\n",
        "ind_cols = {k: find_column(induction_df, v) for k, v in induction_map.items()}\n",
        "\n",
        "# ===============================\n",
        "# ONBOARDING COLUMN MAP\n",
        "# ===============================\n",
        "onboarding_map = {\n",
        "    \"role_match\": [\"role matches your expectations\"],\n",
        "    \"training\": [\"initial training\"],\n",
        "    \"role_clarity\": [\"clear and concise explanation\"],\n",
        "    \"hr\": [\"HR practices\"],\n",
        "    \"happiness\": [\"How happy are you\"]\n",
        "}\n",
        "\n",
        "onb_cols = {k: find_column(onboarding_df, v) for k, v in onboarding_map.items()}\n",
        "\n",
        "# ===============================\n",
        "# MERGE DATASETS\n",
        "# ===============================\n",
        "common_col = list(set(induction_df.columns) & set(onboarding_df.columns))[0]\n",
        "df = induction_df.merge(onboarding_df, on=common_col)\n",
        "df.rename(columns={common_col: \"Employee\"}, inplace=True)\n",
        "\n",
        "# ===============================\n",
        "# PSYCHOLOGICAL PARAMETERS\n",
        "# ===============================\n",
        "def compute_parameters(row):\n",
        "    social = (\n",
        "        decode(row[ind_cols[\"buddy\"]]) +\n",
        "        decode(row[ind_cols[\"manager\"]]) +\n",
        "        decode(row[ind_cols[\"support\"]])\n",
        "    ) / 3\n",
        "\n",
        "    process = (\n",
        "        decode(row[ind_cols[\"documents\"]]) +\n",
        "        decode(row[ind_cols[\"it\"]]) +\n",
        "        decode(row[ind_cols[\"admin\"]]) +\n",
        "        decode(row[ind_cols[\"finance\"]])\n",
        "    ) / 4\n",
        "\n",
        "    trust = (\n",
        "        decode(row[ind_cols[\"prehire\"]]) +\n",
        "        decode(row[onb_cols[\"hr\"]]) +\n",
        "        decode(row[ind_cols[\"satisfaction\"]])\n",
        "    ) / 3\n",
        "\n",
        "    autonomy = (\n",
        "        decode(row[onb_cols[\"role_clarity\"]]) +\n",
        "        decode(row[onb_cols[\"training\"]])\n",
        "    ) / 2\n",
        "\n",
        "    return social, process, trust, autonomy\n",
        "\n",
        "# ===============================\n",
        "# STYLE CLASSIFIERS\n",
        "# ===============================\n",
        "def induction_style(s, p):\n",
        "    if s >= 3.5 and p >= 3.5: return \"Supported Integrator\"\n",
        "    if s >= 3.5: return \"People-Dependent\"\n",
        "    if p >= 3.5: return \"System-Dependent\"\n",
        "    return \"Self-Navigator\"\n",
        "\n",
        "def onboarding_style(t, a):\n",
        "    if t >= 3.5 and a >= 3.5: return \"Fast Integrator\"\n",
        "    if t >= 3.5: return \"Guided Learner\"\n",
        "    if a >= 3.5: return \"Independent Skeptic\"\n",
        "    return \"At-Risk Joiner\"\n",
        "\n",
        "# ===============================\n",
        "# SCORES OUT OF 100\n",
        "# ===============================\n",
        "def compute_total_scores(s, p, t, a):\n",
        "    onboarding_score = round(((s + p + t) / 3) * 20, 1)\n",
        "    adjustment_score = round(((a + t + (5 - abs(s - p))) / 3) * 20, 1)\n",
        "    return onboarding_score, adjustment_score\n",
        "\n",
        "# ===============================\n",
        "# RANKING\n",
        "# ===============================\n",
        "score_rows = []\n",
        "\n",
        "for _, row in df.iterrows():\n",
        "    s, p, t, a = compute_parameters(row)\n",
        "    o, ad = compute_total_scores(s, p, t, a)\n",
        "    score_rows.append([row[\"Employee\"], o, ad])\n",
        "\n",
        "rank_df = pd.DataFrame(score_rows, columns=[\"Employee\", \"Onboarding\", \"Adjustment\"])\n",
        "rank_df[\"Onboarding Rank\"] = rank_df[\"Onboarding\"].rank(ascending=False).astype(int)\n",
        "rank_df[\"Adjustment Rank\"] = rank_df[\"Adjustment\"].rank(ascending=False).astype(int)\n",
        "\n",
        "rank_map = {\n",
        "    r.Employee: {\n",
        "        \"onboarding\": r[\"Onboarding Rank\"],\n",
        "        \"adjustment\": r[\"Adjustment Rank\"]\n",
        "    }\n",
        "    for _, r in rank_df.iterrows()\n",
        "}\n",
        "\n",
        "# ===============================\n",
        "# RADAR PLOT\n",
        "# ===============================\n",
        "def radar_plot(values, name):\n",
        "    labels = [\"Social Support\", \"Process Orientation\", \"Trust\", \"Autonomy\"]\n",
        "    angles = [n / 4 * 2 * math.pi for n in range(4)]\n",
